<resources>
    <style name="AppTheme" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">@color/iv_background</item>
        <item name="android:navigationBarColor">@color/iv_background</item>
        <item name="android:statusBarColor">@color/iv_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AppTheme.Splash" parent="@style/AppTheme">
        <item name="android:windowBackground">@color/iv_background</item>
        <item name="android:navigationBarColor">@color/iv_background</item>
        <item name="android:statusBarColor">@color/iv_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
